// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 🌍 ENUM DIVISIÓN
enum Division {
  JUGUETERIA
  FIESTAS
}

enum Role {
  ADMIN
  SELLER
  USER
}

// 👤 USUARIOS (Modificado para Google)
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? // 👈 Requerido por Google
  image         String?   // 👈 Foto de Google
  password      String?   // 👈 OJO: Ahora es opcional (?)
  role          Role      @default(USER)
  
  accounts      Account[] // 👈 Relación obligatoria
  sessions      Session[]
  
  // Tus relaciones existentes
  orders        Order[]     
  addresses     Address[]   
  favorites     Favorite[]  
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 🔐 TABLAS DE NEXTAUTH (OBLIGATORIAS PARA GOOGLE)
model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}    

// 📍 DIRECCIONES
model Address {
  id        String   @id @default(uuid())
  dni       String?  // 👈 Ya lo tienes, ¡bien!
  firstName String
  lastName  String
  phone     String
  address   String   
  address2  String?  
  city      String   
  province  String?
  country   String   @default("Perú") // 👈 AGREGA ESTO
  
  user      User     @relation(fields: [userId], references: [id])
  userId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ❤️ FAVORITOS
model Favorite {
  id        String   @id @default(uuid())
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  // 👇 AGREGA ESTAS DOS LÍNEAS:
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

// 📦 PRODUCTOS
model Product {
  id          String   @id @default(uuid())
  title       String
  description String
  slug        String   @unique
  price       Decimal  @default(0) @db.Decimal(10, 2)
  stock       Int      @default(0)
  images      String[]
  
  isAvailable Boolean  @default(true)
  
  wholesalePrice     Decimal? @db.Decimal(10, 2) 
  wholesaleMinCount  Int?     
  
  discountPercentage Int      @default(0) 
  
  tags               String[] 
  
  color       String?
  groupTag    String?

  division    Division @default(JUGUETERIA)
  
  category    Category @relation(fields: [categoryId], references: [id])
  categoryId  String

  orderItems  OrderItem[]
  favorites   Favorite[] 

  barcode     String?  @unique // Para escanear rápido

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 🗂️ CATEGORÍAS
model Category {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  division  Division @default(JUGUETERIA)
  image     String?  

  products  Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 🛍️ PEDIDOS
model Order {
  id             String      @id @default(uuid())
  receiptNumber String?     @unique
  totalAmount    Decimal     @db.Decimal(10, 2)
  totalItems     Int
  status         OrderStatus @default(PENDING)
  isPaid         Boolean     @default(false)

  mercadoPagoId   String?     @unique // ID de la preferencia o del pago de MP

  clientName     String
  clientPhone    String
  deliveryMethod String      @default("PICKUP") 
  shippingAddress String?
  shippingCost   Decimal     @default(0) @db.Decimal(10, 2)
  notes          String?
  
  user           User?       @relation(fields: [userId], references: [id])
  userId         String?

  orderItems     OrderItem[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model OrderItem {
  id        String  @id @default(uuid())
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String

  product   Product @relation(fields: [productId], references: [id])
  productId String
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  CANCELLED
}

model StoreConfig {
  id             String   @id @default(uuid())
  whatsappPhone  String   @default("51999999999")
  welcomeMessage String   @default("Hola Festamas, quiero confirmar mi pedido...")
  localDeliveryPrice Decimal @default(10.00) @db.Decimal(10, 2)
  heroImage       String?
  heroTitle       String   @default("Juguetes y Alegría")
  heroSubtitle    String   @default("Encuentra el regalo perfecto en Festamas")
  heroButtonText  String   @default("Ver Juguetes")
  heroButtonLink  String   @default("#catalogo")
  heroBtnColor    String   @default("#fb3099")
  updatedAt       DateTime @updatedAt
}

// 🎫 CUPONES
model Coupon {
  id             String      @id @default(uuid())
  code           String      @unique
  discount       Decimal     @db.Decimal(10, 2)
  type           CouponType  @default(FIXED)
  isActive       Boolean     @default(true)
  
  // 🚀 Nuevos Campos
  expirationDate DateTime?   // Si es null, no expira nunca
  maxUses        Int?        // Si es null, usos infinitos
  currentUses    Int         @default(0) // Contador real de usos
  division       Division    @default(JUGUETERIA) // Scope del cupón

  createdAt      DateTime    @default(now())
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum BannerPosition {
  MAIN_HERO
  MIDDLE_SECTION
}

model Banner {
  id        String   @id @default(uuid())
  title     String   
  subtitle  String?
  imageUrl  String   
  mobileUrl String?  
  link      String?  
  position  BannerPosition
  division  Division 
  active    Boolean  @default(true)
  order     Int      @default(0) 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeSection {
  id          String   @id @default(uuid())
  title       String   
  subtitle    String?  
  tag         String   
  division    Division @default(JUGUETERIA)
  icon        String   @default("star")
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 📖 CATÁLOGOS INTERACTIVOS
model Catalog {
  id         String   @id @default(uuid())
  title      String   
  coverImage String   // Imagen de portada
  iframeUrl  String   // El link de Flipsnack/Heyzine
  division   Division @default(JUGUETERIA) // Festamas o FiestasYa
  isActive   Boolean  @default(true) // Para ocultarlo sin borrarlo
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

