generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 🌍 ENUMS
// ==========================================
enum Role {
  ADMIN
  SELLER
  SUPER_ADMIN
  OWNER
  MANAGER
  CASHIER
  USER // Cliente E-commerce
}

enum PaymentMethod {
  CASH
  YAPE
  PLIN
  CARD
  TRANSFER
  POINTS // Pagar con puntos
}

enum InvoiceType {
  BOLETA
  FACTURA
  NOTA_VENTA
}

enum InvoiceStatus {
  PENDING
  SENT
  ACCEPTED
  REJECTED
  VOIDED
}

enum NotificationType {
  CASH_OPENED
  CASH_CLOSED
  DAILY_SUMMARY
  ALERT
  VOID_REQUEST
  TRANSFER_REQUEST
  TRANSFER_UPDATE
  HR_ADVANCE_REQUEST
  HR_ADVANCE_UPDATE
  HR_BONUS_CREATED
  HR_BONUS_APPLIED
  HR_PAYROLL_GENERATED
  HR_PAYROLL_PAID
  ORDER_NEW
  ORDER_STATUS_UPDATE
}

enum TransferStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum AuditAction {
  LOGIN
  LOGOUT
  CREATE_SALE
  VOID_SALE
  OPEN_CASH
  CLOSE_CASH
  UPDATE_STOCK
  UPDATE_PURCHASE_COSTS
  CREATE_USER
  DELETE_USER
  SYSTEM_ERROR
}

enum ProductType {
  STANDARD
  COMBO
}

enum SalesChannel {
  POS
  ECOMMERCE
  BOTH
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CouponType {
  FIXED
  PERCENTAGE
}

enum ReturnRequestStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum BannerPosition {
  TOP_BAR
  MAIN_HERO
  MIDDLE_SECTION
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  READY_FOR_PICKUP
  DELIVERED
  CANCELLED
}

enum LayoutStyle {
  CAROUSEL
  GRID_STANDARD
  GRID_HIGHLIGHT
  LIST_COMPACT
}

enum PointTransactionType {
  EARN
  REDEEM
  MANUAL_ADJUSTMENT
  EXPIRED
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

enum MovementType {
  INPUT // Entrada manual
  OUTPUT // Salida manual
  ADJUSTMENT // Ajuste por inventario
  SALE_POS // Venta en tienda
  SALE_ECOMMERCE // Venta online
  PURCHASE // Compra a proveedor
  TRANSFER // Traslado entre tiendas
  RETURN_POS // Devolución en tienda
  RETURN_ECOMMERCE // Devolución online
  RESERVATION // Reserva de stock
}

enum AttendanceStatus {
  PRESENT
  LATE
  ABSENT
  EXCUSED
  SICK
  VACATION
  HALF_DAY
}

enum ShiftType {
  MORNING
  AFTERNOON
  NIGHT
  FULL_DAY
  CUSTOM
}

enum PayrollType {
  WEEKLY
  MONTHLY
}

enum BonusType {
  PUNCTUALITY
  PERFORMANCE
  SALES_TARGET
  MANUAL
}

enum AdvanceStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum CustomerTier {
  REGULAR
  SILVER
  GOLD
  PLATINUM
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

// ==========================================
// 💰 ACCOUNTING ENUMS
// ==========================================
enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum TransactionSource {
  MANUAL
  SALE
  PURCHASE
  CASH_SESSION
  INVENTORY
  ADJUSTMENT
}

enum FiscalPeriodStatus {
  OPEN
  CLOSED
}

// ==========================================
// 👤 USUARIOS Y RRHH (ERP)
// ==========================================
model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  pin           String? // Para acceso rápido en POS
  isActive      Boolean   @default(true)

  // Relaciones E-commerce / NextAuth
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     Address[]
  favorites     Favorite[]
  reviews       Review[]
  viewHistory   ViewHistory[]
  searchHistory SearchHistory[]

  // 🔥 EL PUENTE OMNICANAL: Conecta el usuario web con el cliente POS
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Relaciones POS/Negocio
  businessId  String?
  branchId    String?
  permissions Json?
  business    Business? @relation(fields: [businessId], references: [id])
  branch      Branch?   @relation(fields: [branchId], references: [id])

  // ERP - RRHH
  baseSalary         Decimal?     @db.Decimal(12, 2)
  hourlyRate         Decimal?     @db.Decimal(12, 2)
  workingHours       Int?         @default(8)
  expectedCheckIn    String?
  expectedCheckOut   String?
  qrCode             String?      @unique
  barcode            String?      @unique
  position           String?
  hireDate           DateTime?
  attendances        Attendance[]
  markedAttendances  Attendance[] @relation("MarkedBy")
  pushSubscriptions  PushSubscription[]
  quotes             Quote[]
  payrolls           Payroll[]
  shifts             Shift[]
  bonuses            Bonus[]
  advances           Advance[]
  workSessions       WorkSession[]

  // Transaccional
  cashSessions   CashSession[]
  sales          Sale[]
  auditLogs      AuditLog[]
  stockTransfers StockTransfer[]
  stockMovements StockMovement[]
  purchaseOrders PurchaseOrder[]
  cartItems      CartItem[]

  // Accounting
  journalEntries      JournalEntry[]
  fiscalPeriodsClosed FiscalPeriod[]
  bankReconciliations BankReconciliation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([branchId])
}

model Attendance {
  id            String           @id @default(uuid())
  userId        String
  branchId      String
  date          DateTime         @db.Date
  checkIn       DateTime?
  checkOut      DateTime?
  status        AttendanceStatus @default(PRESENT)
  notes         String?
  hoursWorked   Decimal?         @db.Decimal(5, 2)
  isLate        Boolean          @default(false)
  lateMinutes   Int?             @default(0)
  calculatedPay Decimal?         @db.Decimal(10, 2)
  markedBy      String?

  user   User    @relation(fields: [userId], references: [id])
  branch Branch  @relation(fields: [branchId], references: [id])
  marker User?   @relation("MarkedBy", fields: [markedBy], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date, branchId])
  @@index([userId, date])
  @@index([branchId, date])
}

model Shift {
  id          String    @id @default(uuid())
  userId      String
  name        String
  type        ShiftType @default(FULL_DAY)
  startTime   String
  endTime     String
  workingDays Json
  isActive    Boolean   @default(true)

  user         User          @relation(fields: [userId], references: [id])
  workSessions WorkSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WorkSession {
  id        String    @id @default(uuid())
  userId    String
  shiftId   String?
  startTime DateTime
  endTime   DateTime?
  isActive  Boolean   @default(true)
  notes     String?

  user  User   @relation(fields: [userId], references: [id])
  shift Shift? @relation(fields: [shiftId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startTime])
}

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Payroll {
  id            String      @id @default(uuid())
  userId        String
  periodStart   DateTime
  periodEnd     DateTime
  type          PayrollType @default(WEEKLY)
  baseAmount    Decimal     @db.Decimal(12, 2)
  hoursWorked   Decimal     @default(0) @db.Decimal(6, 2)
  overtimeHours Decimal     @default(0) @db.Decimal(6, 2)
  bonusAmount   Decimal     @default(0) @db.Decimal(12, 2)
  deductions    Decimal     @default(0) @db.Decimal(12, 2)
  advanceAmount Decimal     @default(0) @db.Decimal(12, 2)
  totalPaid     Decimal     @db.Decimal(12, 2)
  isPaid        Boolean     @default(false)
  paidAt        DateTime?
  notes         String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, periodStart])
}

model Bonus {
  id          String    @id @default(uuid())
  userId      String
  type        BonusType
  amount      Decimal   @db.Decimal(12, 2)
  description String
  isApplied   Boolean   @default(false)
  appliedAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Advance {
  id          String        @id @default(uuid())
  userId      String
  amount      Decimal       @db.Decimal(12, 2)
  reason      String
  status      AdvanceStatus @default(PENDING)
  requestedAt DateTime      @default(now())
  approvedAt  DateTime?
  paidAt      DateTime?
  notes       String?

  user User @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 📦 PRODUCTOS, VARIANTES, KARDEX Y COMPRAS
// ==========================================
model Category {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  image     String?
  viewCount Int     @default(0)

  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])

  ecommerceCode String?
  products      Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
}

model UnitOfMeasure {
  id           String @id @default(uuid())
  name         String
  abbreviation String @unique

  variants   ProductVariant[]
  orderItems PurchaseOrderItem[]
}

model Supplier {
  id             String  @id @default(uuid())
  businessId     String
  name           String
  email          String?
  phone          String?
  ruc            String?
  address        String?
  representative String?
  website        String?
  comments       String?
  isActive       Boolean @default(true)

  business       Business        @relation(fields: [businessId], references: [id])
  products       Product[]
  purchaseOrders PurchaseOrder[]

  // Accounting
  accountsPayable AccountsPayable[]

  createdAt DateTime @default(now())
}

model Product {
  id          String      @id @default(uuid())
  title       String
  description String
  slug        String      @unique
  basePrice   Decimal     @default(0) @db.Decimal(10, 2)
  images      String[]
  isAvailable Boolean     @default(true)
  type        ProductType @default(STANDARD)

  cost               Decimal  @default(0) @db.Decimal(12, 2)
  wholesalePrice     Decimal? @db.Decimal(10, 2)
  wholesaleMinCount  Int?
  discountPercentage Int      @default(0)

  minStock Int     @default(5)
  sku      String?
  barcode  String?

  tags                 String[]
  groupTag             String?
  ecommerceDescription String? // Descripción de marketing para la tienda online, separada de la descripción del ERP

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  favorites   Favorite[]
  reviews     Review[]
  viewHistory ViewHistory[]

  comboItems ComboItem[] @relation("ComboParent")

  averageRating Decimal @default(0) @db.Decimal(3, 2)
  reviewCount   Int     @default(0)
  viewCount     Int     @default(0)
  salesCount    Int     @default(0)

  businessId        String?
  branchOwnerId     String?
  active            Boolean      @default(true)
  availableChannels SalesChannel @default(BOTH)
  business          Business?    @relation(fields: [businessId], references: [id])
  branchOwner       Branch?      @relation(fields: [branchOwnerId], references: [id])

  variants ProductVariant[]
  partners PartnerProduct[]

  // SEO fields
  metaTitle       String?
  metaDescription String?
  publishedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([branchOwnerId])
  @@index([categoryId])
  @@index([active])
  @@index([supplierId])
  @@index([businessId, active, categoryId])
  @@index([barcode])
  @@index([sku])
}

model ProductVariant {
  id         String   @id @default(uuid())
  productId  String
  name       String
  attributes Json? // DEPRECATED: Use variantAttributes relation instead
  sku        String?
  barcode    String?  @unique
  active     Boolean  @default(true)
  images     String[]

  uomId String?
  uom   UnitOfMeasure? @relation(fields: [uomId], references: [id])

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  stock             Stock[]
  stockMovements    StockMovement[]
  purchaseItems     PurchaseOrderItem[]
  saleItems         SaleItem[]
  orderItems        OrderItem[]
  transferItems     StockTransferItem[]
  partOfCombos      ComboItem[]         @relation("ComboChild")
  quoteItems        QuoteItem[]
  variantAttributes VariantAttribute[]
  cartItems         CartItem[]
  stockReservations StockReservation[]
  returnItems       ReturnItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, name])
  @@index([productId])
  @@index([barcode])
}

// ==========================================
// 🎨 STRUCTURED ATTRIBUTES SYSTEM
// ==========================================
model AttributeType {
  id         String  @id @default(uuid())
  businessId String
  name       String
  slug       String
  order      Int     @default(0)
  isActive   Boolean @default(true)

  business Business         @relation(fields: [businessId], references: [id])
  values   AttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, slug])
  @@index([businessId, isActive])
}

model AttributeValue {
  id              String  @id @default(uuid())
  attributeTypeId String
  value           String
  slug            String
  hexColor        String?
  image           String?
  order           Int     @default(0)
  isActive        Boolean @default(true)

  attributeType     AttributeType      @relation(fields: [attributeTypeId], references: [id], onDelete: Cascade)
  variantAttributes VariantAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attributeTypeId, slug])
  @@index([attributeTypeId, isActive])
}

model VariantAttribute {
  id               String @id @default(uuid())
  variantId        String
  attributeValueId String

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([variantId, attributeValueId])
  @@index([variantId])
}

model StockMovement {
  id            String       @id @default(uuid())
  variantId     String
  branchId      String?
  warehouseId   String?
  userId        String?
  type          MovementType
  quantity      Int
  previousStock Int
  currentStock  Int
  reason        String?
  createdAt     DateTime     @default(now())

  variant   ProductVariant @relation(fields: [variantId], references: [id])
  branch    Branch?        @relation(fields: [branchId], references: [id])
  warehouse Warehouse?     @relation(fields: [warehouseId], references: [id])
  user      User?          @relation(fields: [userId], references: [id])
}

model PurchaseOrder {
  id           String              @id @default(uuid())
  businessId   String
  supplierId   String?
  createdById  String?
  orderDate    DateTime            @default(now())
  receivedDate DateTime?
  status       PurchaseOrderStatus @default(PENDING)
  totalAmount  Decimal             @db.Decimal(12, 2)
  notes        String?

  business  Business            @relation(fields: [businessId], references: [id])
  supplier  Supplier?           @relation(fields: [supplierId], references: [id])
  createdBy User?               @relation(fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  // Accounting
  accountsPayable AccountsPayable?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String
  variantId       String
  uomId           String?
  quantity        Int
  cost            Decimal @db.Decimal(12, 2)
  costModified    Boolean @default(false)

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])
  uom           UnitOfMeasure? @relation(fields: [uomId], references: [id])
}

model ComboItem {
  id        String @id @default(uuid())
  comboId   String
  variantId String
  quantity  Int    @default(1)

  combo   Product        @relation("ComboParent", fields: [comboId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation("ComboChild", fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([comboId, variantId])
}

model Review {
  id        String       @id @default(uuid())
  productId String
  userId    String
  rating    Int
  comment   String?      @db.Text
  status    ReviewStatus @default(PENDING)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, userId])
}

// ==========================================
// 🏢 ESTRUCTURA DE NEGOCIO Y AFILIADOS
// ==========================================
model Business {
  id           String  @id @default(uuid())
  name         String
  ruc          String  @unique
  address      String?
  logoUrl      String?
  brandColors  Json?
  isActive     Boolean @default(true)
  maxBranches  Int     @default(1)
  maxManagers  Int     @default(1)
  maxEmployees Int     @default(3)

  loyaltyEnabled    Boolean @default(false)
  loyaltyEarnRate   Decimal @default(10) @db.Decimal(10, 2)
  loyaltyRedeemRate Decimal @default(0.1) @db.Decimal(10, 2)

  branches       Branch[]
  warehouses     Warehouse[]
  users          User[]
  products       Product[]
  categories     Category[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  customers      Customer[]
  sales          Sale[]
  sunatConfig    SunatConfig?
  auditLogs      AuditLog[]
  pointLedger    PointTransaction[]
  partners       Partner[]

  // Accounting
  accounts            AccountingAccount[]
  journalEntries      JournalEntry[]
  fiscalPeriods       FiscalPeriod[]
  accountsReceivable  AccountsReceivable[]
  accountsPayable     AccountsPayable[]
  bankReconciliations BankReconciliation[]

  // Attributes
  attributeTypes AttributeType[]

  orders             Order[]
  quotes             Quote[]
  productCollections ProductCollection[]
  returnRequests     ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  id              String  @id @default(uuid())
  businessId      String
  name            String
  address         String?
  phone           String?
  logos           Json?
  brandColors     Json?
  customRuc       String?
  customLegalName String?
  customAddress   String?
  ecommerceCode      String? @unique
  attendanceQrToken  String? @unique
  businessHours      Json?   // { lun:"9:00-18:00", mar:"9:00-18:00", ... } para tienda online

  business       Business        @relation(fields: [businessId], references: [id])
  stock          Stock[]
  stockMovements StockMovement[]
  users          User[]
  cashSessions   CashSession[]
  sales          Sale[]
  transfersOut   StockTransfer[] @relation("TransferFromBranch")
  transfersIn    StockTransfer[] @relation("TransferToBranch")
  attendances    Attendance[]

  banners       Banner[]
  homeSections  HomeSection[]
  catalogs      Catalog[]
  popups        PopupConfig[]
  coupons       Coupon[]
  productsOwned Product[]

  // Accounting
  journalEntries JournalEntry[]

  orders Order[]
  quotes Quote[]
}

// ==========================================
// 🏭 ALMACENES (BODEGAS)
// ==========================================
model Warehouse {
  id         String  @id @default(uuid())
  businessId String
  name       String
  address    String?
  phone      String?
  notes      String?
  isActive   Boolean @default(true)

  business       Business        @relation(fields: [businessId], references: [id])
  stock          Stock[]
  stockMovements StockMovement[]
  transfersOut   StockTransfer[] @relation("TransferFromWarehouse")
  transfersIn    StockTransfer[] @relation("TransferToWarehouse")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([businessId, isActive])
}

model Partner {
  id         String  @id @default(uuid())
  businessId String
  name       String
  city       String
  address    String?
  phone      String?
  website    String?
  isVerified Boolean @default(false)
  logoUrl    String?

  business Business         @relation(fields: [businessId], references: [id])
  products PartnerProduct[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PartnerProduct {
  id        String @id @default(uuid())
  partnerId String
  productId String

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([partnerId, productId])
}

// ==========================================
// 💸 OPERACIONES Y PUNTOS
// ==========================================
model Stock {
  id          String  @id @default(uuid())
  branchId    String?
  warehouseId String?
  variantId   String
  quantity    Int     @default(0)

  branch    Branch?    @relation(fields: [branchId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  updatedAt DateTime @updatedAt

  @@unique([branchId, variantId])
  @@unique([warehouseId, variantId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([branchId, quantity])
}

model CashSession {
  id          String    @id @default(uuid())
  branchId    String
  userId      String
  openedAt    DateTime  @default(now())
  closedAt    DateTime?
  initialCash Decimal   @db.Decimal(12, 2)
  finalCash   Decimal?  @db.Decimal(12, 2)
  income      Decimal   @default(0) @db.Decimal(12, 2)
  expense     Decimal   @default(0) @db.Decimal(12, 2)
  difference  Decimal?  @db.Decimal(12, 2)
  incidents   String?
  status      String    @default("OPEN")

  branch       Branch            @relation(fields: [branchId], references: [id])
  user         User              @relation(fields: [userId], references: [id])
  sales        Sale[]
  transactions CashTransaction[]
}

model CashTransaction {
  id            String   @id @default(uuid())
  cashSessionId String
  type          String
  amount        Decimal  @db.Decimal(12, 2)
  description   String
  createdAt     DateTime @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id])

  @@index([cashSessionId])
}

model Customer {
  id         String  @id @default(uuid())
  businessId String
  name       String
  docType    String?
  docNumber  String?
  email      String?
  phone      String?

  totalSpent   Decimal   @default(0) @db.Decimal(12, 2)
  visits       Int       @default(0)
  lastPurchase DateTime?

  pointsBalance Int   @default(0)
  userAccount   User?

  address      String?
  birthdate    DateTime?
  gender       String?
  notes        String?
  tags         String[]
  tier         CustomerTier @default(REGULAR)
  priceLevel   String       @default("RETAIL") // RETAIL | WHOLESALE | VIP
  referredById String?
  referredBy   Customer?    @relation("CustomerReferral", fields: [referredById], references: [id])
  referrals    Customer[]   @relation("CustomerReferral")

  business    Business           @relation(fields: [businessId], references: [id])
  sales       Sale[]
  pointLedger PointTransaction[]
  quotes      Quote[]
  children    CustomerChild[]

  // Accounting
  accountsReceivable AccountsReceivable[]

  @@unique([businessId, docNumber])
  @@index([businessId, tier])
}

model CustomerChild {
  id         String   @id @default(uuid())
  customerId String
  name       String
  birthdate  DateTime
  notes      String?
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

model Sale {
  id            String  @id @default(uuid())
  code          String  @default(cuid())
  externalId    String? @unique
  businessId    String?
  branchId      String
  cashSessionId String?
  userId        String
  customerId    String?
  notes         String?

  subtotal       Decimal @db.Decimal(12, 2)
  discount       Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)
  tenderedAmount Decimal @db.Decimal(12, 2)
  changeAmount   Decimal @default(0) @db.Decimal(12, 2)

  pointsEarned   Int @default(0)
  pointsRedeemed Int @default(0)

  status    String   @default("COMPLETED")
  createdAt DateTime @default(now())

  quoteId String? @unique

  business    Business?          @relation(fields: [businessId], references: [id])
  branch      Branch             @relation(fields: [branchId], references: [id])
  user        User               @relation(fields: [userId], references: [id])
  customer    Customer?          @relation(fields: [customerId], references: [id])
  cashSession CashSession?       @relation(fields: [cashSessionId], references: [id])
  items       SaleItem[]
  payments    SalePayment[]
  invoice     Invoice?
  pointLedger PointTransaction[]
  quote       Quote?             @relation(fields: [quoteId], references: [id])

  // Accounting
  accountsReceivable AccountsReceivable?
}

model SaleItem {
  id          String  @id @default(uuid())
  saleId      String
  variantId   String?
  productName String
  variantName String?
  quantity    Int
  price       Decimal @db.Decimal(12, 2)
  subtotal    Decimal @db.Decimal(12, 2)
  notes       String?

  sale    Sale            @relation(fields: [saleId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([saleId])
}

model SalePayment {
  id        String        @id @default(uuid())
  saleId    String
  method    PaymentMethod
  amount    Decimal       @db.Decimal(12, 2)
  reference String?

  sale Sale @relation(fields: [saleId], references: [id])
}

model Invoice {
  id          String        @id @default(uuid())
  saleId      String        @unique
  invoiceType InvoiceType
  serie       String
  number      Int
  status      InvoiceStatus @default(PENDING)
  pdfUrl      String?
  xmlUrl      String?
  cdrUrl      String?
  issuedAt    DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
}

model SunatConfig {
  id           String  @id @default(uuid())
  businessId   String  @unique
  solUser      String?
  solPassword  String?
  certPassword String?
  active       Boolean @default(false)

  business Business @relation(fields: [businessId], references: [id])
}

model Notification {
  id         String           @id @default(uuid())
  userId     String?
  businessId String?
  title      String
  message    String
  type       NotificationType
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())
}

model AuditLog {
  id         String      @id @default(uuid())
  businessId String
  userId     String?
  action     AuditAction
  details    Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  business Business @relation(fields: [businessId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
}

model StockTransfer {
  id              String         @id @default(uuid())
  fromBranchId    String?
  fromWarehouseId String?
  toBranchId      String?
  toWarehouseId   String?
  requestedById   String
  status          TransferStatus @default(PENDING)
  notes           String?

  fromBranch    Branch?    @relation("TransferFromBranch",    fields: [fromBranchId],    references: [id])
  fromWarehouse Warehouse? @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toBranch      Branch?    @relation("TransferToBranch",      fields: [toBranchId],      references: [id])
  toWarehouse   Warehouse? @relation("TransferToWarehouse",   fields: [toWarehouseId],   references: [id])
  requestedBy   User       @relation(fields: [requestedById], references: [id])
  items         StockTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockTransferItem {
  id         String @id @default(uuid())
  transferId String
  variantId  String
  quantity   Int

  transfer StockTransfer  @relation(fields: [transferId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])
}

model PointTransaction {
  id         String @id @default(uuid())
  businessId String
  customerId String

  points      Int
  type        PointTransactionType
  description String?

  saleId  String?
  orderId String?

  business Business @relation(fields: [businessId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale?    @relation(fields: [saleId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  createdAt DateTime @default(now())

  @@index([customerId])
}

// ==========================================
// 🛒 E-COMMERCE
// ==========================================
model Address {
  id       String  @id @default(uuid())
  address  String
  address2 String?
  city     String
  province String?
  country  String  @default("Perú")

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String @id @default(uuid())
  userId    String
  productId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
}

model ViewHistory {
  id        String  @id @default(uuid())
  userId    String?
  sessionId String?
  productId String

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  viewedAt DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
}

model SearchHistory {
  id        String  @id @default(uuid())
  userId    String?
  sessionId String?
  query     String

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  searchedAt DateTime @default(now())
}

model Order {
  id              String      @id @default(uuid())
  businessId      String?
  branchId        String?
  receiptNumber   String?     @unique
  totalAmount     Decimal     @db.Decimal(10, 2)
  totalItems      Int
  status          OrderStatus @default(PENDING)
  isPaid          Boolean     @default(false)
  mercadoPagoId   String?     @unique
  clientName      String
  clientPhone     String
  deliveryMethod  String      @default("PICKUP")
  shippingAddress String?
  shippingCost    Decimal     @default(0) @db.Decimal(10, 2)
  notes           String?
  source          String      @default("ONLINE")

  trackingNumber  String?
  carrier         String?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  cancelReason    String?

  termsAcceptedAt DateTime?

  pointsEarned   Int @default(0)
  pointsRedeemed Int @default(0)

  userId   String?
  user     User?              @relation(fields: [userId], references: [id])
  business Business?          @relation(fields: [businessId], references: [id])
  branch   Branch?            @relation(fields: [branchId], references: [id])

  orderItems      OrderItem[]
  trackingEvents  OrderTracking[]
  pointLedger     PointTransaction[]
  returnRequests  ReturnRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId])
  @@index([branchId])
  @@index([status])
}

model OrderItem {
  id          String  @id @default(uuid())
  orderId     String
  variantId   String?
  productName String
  variantName String?
  quantity    Int
  price       Decimal @db.Decimal(10, 2)

  order   Order           @relation(fields: [orderId], references: [id])
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}

model OrderTracking {
  id          String      @id @default(uuid())
  orderId     String
  status      OrderStatus
  description String
  location    String?

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model ProductCollection {
  id          String    @id @default(uuid())
  businessId  String
  name        String
  slug        String
  description String?
  coverImage  String?
  groupTag    String    // Coincide con Product.groupTag para filtrar productos
  activeFrom  DateTime?
  activeUntil DateTime? // Para colecciones estacionales (Navidad, Halloween, etc.)
  sortOrder   Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  business Business @relation(fields: [businessId], references: [id])

  @@unique([businessId, slug])
  @@index([businessId, active])
}

model StoreConfig {
  id                 String  @id @default(uuid())
  whatsappPhone      String  @default("51999999999")
  welcomeMessage     String  @default("Hola Festamas, quiero confirmar mi pedido...")
  localDeliveryPrice Decimal @default(10.00) @db.Decimal(10, 2)

  heroImage      String?
  heroTitle      String  @default("Juguetes y Alegría")
  heroSubtitle   String  @default("Encuentra el regalo perfecto en Festamas")
  heroButtonText String  @default("Ver Juguetes")
  heroButtonLink String  @default("#catalogo")
  heroBtnColor   String  @default("#fb3099")

  topBarActive Boolean @default(true)
  topBarText   String  @default("¡Envíos gratis por compras mayores a S/100!")
  topBarLink   String?

  updatedAt DateTime @updatedAt
}

model PopupConfig {
  id       String  @id @default(uuid())
  branchId String?
  imageUrl String
  link     String?
  isActive Boolean @default(false)
  showOnce Boolean @default(true)

  branch    Branch?  @relation(fields: [branchId], references: [id])
  updatedAt DateTime @updatedAt
}

model Coupon {
  id             String     @id @default(uuid())
  branchId       String?
  code           String     @unique
  discount       Decimal    @db.Decimal(10, 2)
  type           CouponType @default(FIXED)
  isActive       Boolean    @default(true)
  expirationDate DateTime?
  maxUses        Int?
  currentUses    Int        @default(0)

  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
}

model Banner {
  id        String         @id @default(uuid())
  branchId  String?
  title     String
  subtitle  String?
  imageUrl  String
  mobileUrl String?
  link      String?
  position  BannerPosition
  active    Boolean        @default(true)
  order     Int            @default(0)

  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomeSection {
  id          String      @id @default(uuid())
  branchId    String?
  title       String
  subtitle    String?
  tag         String
  layoutStyle LayoutStyle @default(CAROUSEL)
  icon        String      @default("star")
  order       Int         @default(0)
  isActive    Boolean     @default(true)

  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Catalog {
  id         String  @id @default(uuid())
  branchId   String?
  title      String
  coverImage String
  iframeUrl  String
  isActive   Boolean @default(true)

  branch    Branch?  @relation(fields: [branchId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 💰 ACCOUNTING MODULE
// ==========================================
model AccountingAccount {
  id         String      @id @default(uuid())
  businessId String
  code       String
  name       String
  type       AccountType
  parentId   String?
  isActive   Boolean     @default(true)
  balance    Decimal     @default(0) @db.Decimal(15, 2)

  business Business            @relation(fields: [businessId], references: [id])
  parent   AccountingAccount?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children AccountingAccount[] @relation("AccountHierarchy")

  journalLines        JournalEntryLine[]
  bankReconciliations BankReconciliation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, code])
  @@index([businessId, type])
  @@index([businessId, isActive])
}

model JournalEntry {
  id           String            @id @default(uuid())
  businessId   String
  branchId     String
  entryNumber  Int
  entryDate    DateTime
  description  String
  source       TransactionSource
  sourceId     String?
  isReversed   Boolean           @default(false)
  reversalOfId String?
  attachments  String[]

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  business   Business       @relation(fields: [businessId], references: [id])
  branch     Branch         @relation(fields: [branchId], references: [id])
  createdBy  User           @relation(fields: [createdById], references: [id])
  reversalOf JournalEntry?  @relation("JournalReversal", fields: [reversalOfId], references: [id])
  reversals  JournalEntry[] @relation("JournalReversal")

  lines                   JournalEntryLine[]
  bankReconciliationItems BankReconciliationItem[]

  @@unique([businessId, entryNumber])
  @@index([businessId, entryDate])
  @@index([branchId, entryDate])
  @@index([source, sourceId])
}

model JournalEntryLine {
  id             String  @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Decimal @default(0) @db.Decimal(15, 2)
  credit         Decimal @default(0) @db.Decimal(15, 2)
  description    String?

  journalEntry JournalEntry      @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      AccountingAccount @relation(fields: [accountId], references: [id])

  @@index([journalEntryId])
  @@index([accountId])
}

model FiscalPeriod {
  id         String             @id @default(uuid())
  businessId String
  name       String
  startDate  DateTime
  endDate    DateTime
  status     FiscalPeriodStatus @default(OPEN)
  closedAt   DateTime?
  closedById String?

  business Business @relation(fields: [businessId], references: [id])
  closedBy User?    @relation(fields: [closedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId, status])
}

model AccountsReceivable {
  id          String   @id @default(uuid())
  businessId  String
  customerId  String
  saleId      String   @unique
  invoiceDate DateTime
  dueDate     DateTime
  amount      Decimal  @db.Decimal(12, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2)
  balance     Decimal  @db.Decimal(12, 2)

  business Business @relation(fields: [businessId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
  sale     Sale     @relation(fields: [saleId], references: [id])

  payments ARPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, customerId])
  @@index([dueDate])
}

model ARPayment {
  id          String   @id @default(uuid())
  arId        String
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime
  reference   String?

  ar AccountsReceivable @relation(fields: [arId], references: [id])

  createdAt DateTime @default(now())
}

model AccountsPayable {
  id          String   @id @default(uuid())
  businessId  String
  supplierId  String
  purchaseId  String   @unique
  invoiceDate DateTime
  dueDate     DateTime
  amount      Decimal  @db.Decimal(12, 2)
  paidAmount  Decimal  @default(0) @db.Decimal(12, 2)
  balance     Decimal  @db.Decimal(12, 2)

  business Business      @relation(fields: [businessId], references: [id])
  supplier Supplier      @relation(fields: [supplierId], references: [id])
  purchase PurchaseOrder @relation(fields: [purchaseId], references: [id])

  payments APPayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, supplierId])
  @@index([dueDate])
}

model APPayment {
  id          String   @id @default(uuid())
  apId        String
  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime
  reference   String?

  ap AccountsPayable @relation(fields: [apId], references: [id])

  createdAt DateTime @default(now())
}

model BankReconciliation {
  id               String    @id @default(uuid())
  businessId       String
  accountId        String
  statementDate    DateTime
  statementBalance Decimal   @db.Decimal(15, 2)
  bookBalance      Decimal   @db.Decimal(15, 2)
  difference       Decimal   @db.Decimal(15, 2)
  isReconciled     Boolean   @default(false)
  reconciledAt     DateTime?
  reconciledById   String?

  business     Business          @relation(fields: [businessId], references: [id])
  account      AccountingAccount @relation(fields: [accountId], references: [id])
  reconciledBy User?             @relation(fields: [reconciledById], references: [id])

  items BankReconciliationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, accountId])
}

model BankReconciliationItem {
  id               String  @id @default(uuid())
  reconciliationId String
  journalEntryId   String
  isCleared        Boolean @default(false)

  reconciliation BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  journalEntry   JournalEntry       @relation(fields: [journalEntryId], references: [id])

  @@index([reconciliationId])
}

// ==========================================
// 💬 COTIZACIONES
// ==========================================
model Quote {
  id         String      @id @default(uuid())
  code       String      @default(cuid())
  businessId String
  branchId   String
  userId     String
  customerId String?

  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?
  notes      String?

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  convertedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  business Business         @relation(fields: [businessId], references: [id])
  branch   Branch           @relation(fields: [branchId], references: [id])
  user     User             @relation(fields: [userId], references: [id])
  customer Customer?        @relation(fields: [customerId], references: [id])
  sale     Sale?
  items    QuoteItem[]

  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model QuoteItem {
  id          String  @id @default(uuid())
  quoteId     String
  variantId   String?
  productName String
  variantName String?
  quantity    Int
  price       Decimal @db.Decimal(12, 2)
  discount    Decimal @default(0) @db.Decimal(12, 2)
  subtotal    Decimal @db.Decimal(12, 2)

  quote   Quote           @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}

// ==========================================
// 🛒 CART (Persistencia cross-device)
// ==========================================
model CartItem {
  id        String   @id @default(uuid())
  userId    String
  variantId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
}

// ==========================================
// 📦 STOCK RESERVATION
// ==========================================
model StockReservation {
  id        String   @id @default(uuid())
  variantId String
  userId    String?
  quantity  Int
  expiresAt DateTime
  createdAt DateTime @default(now())

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([expiresAt])
}

// ==========================================
// 🔄 DEVOLUCIONES
// ==========================================
model ReturnRequest {
  id         String             @id @default(uuid())
  businessId String
  orderId    String
  userId     String?
  reason     String
  status     ReturnRequestStatus @default(PENDING)
  notes      String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  business Business      @relation(fields: [businessId], references: [id])
  order    Order         @relation(fields: [orderId], references: [id])
  items    ReturnItem[]

  @@index([businessId])
  @@index([orderId])
}

model ReturnItem {
  id              String  @id @default(uuid())
  returnRequestId String
  variantId       String?
  productName     String
  variantName     String?
  quantity        Int
  price           Decimal @db.Decimal(10, 2)

  returnRequest ReturnRequest  @relation(fields: [returnRequestId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
}
